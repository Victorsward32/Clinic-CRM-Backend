                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/queue/{{queue_id}}/skip"
          }
        },
        {
          "name": "Manual Queue Status Update - Optional",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/queue/{{queue_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"{{queue_status_update}}\"\n}"
            }
          }
        }
      ]
