{
  "info": {
    "name": "Clinic CRM - Production Hardened Flow",
    "_postman_id": "7c0f2092-1f8a-4674-a6ba-58f645f53ce2",
    "description": "Run folders top-to-bottom for end-to-end flow. This collection auto-saves tokens and IDs in environment variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{doctor_name}}\",\n  \"email\": \"{{doctor_email}}\",\n  \"phone\": \"{{doctor_phone}}\",\n  \"password\": \"{{doctor_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('doctor_token', json.token);",
                  "if (json.user && json.user._id) pm.environment.set('doctor_id', json.user._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"password\": \"{{doctor_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Register Staff (Doctor Auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) pm.environment.set('staff_member_id', json.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{staff_name}}\",\n  \"email\": \"{{staff_email}}\",\n  \"phone\": \"{{staff_phone}}\",\n  \"password\": \"{{staff_password}}\",\n  \"role\": \"{{staff_role}}\"\n}"
            },
            "url": "{{base_url}}/auth/register-staff"
          }
        },
        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('staff_token', json.token);",
                  "if (json.user && json.user._id) pm.environment.set('staff_id', json.user._id);",
                  "if (json.doctorId) pm.environment.set('staff_doctor_id', json.doctorId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{staff_email}}\",\n  \"password\": \"{{staff_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Forget Password (OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/forget-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\"\n}"
            }
          }
        },
        {
          "name": "Reset Password (Manual OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"otp\": \"{{reset_otp}}\",\n  \"newPassword\": \"{{reset_password_new}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "02 - Patients",
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) pm.environment.set('patient_id', json.data._id);",
                  "if (json.data && json.data.phoneNumber) pm.environment.set('patient_phone_number', json.data.phoneNumber);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{patient_name}}\",\n  \"age\": {{patient_age}},\n  \"gender\": \"{{patient_gender}}\",\n  \"phoneNumber\": \"{{patient_phone_number}}\",\n  \"email\": \"{{patient_email}}\",\n  \"address\": \"{{patient_address}}\",\n  \"weight\": {{patient_weight}},\n  \"height\": {{patient_height}}\n}"
            },
            "url": "{{base_url}}/patient"
          }
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/patient?search={{patient_name}}"
          }
        },
        {
          "name": "Get Patient By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/patient/{{patient_id}}"
          }
        },
        {
          "name": "Get Patient History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/patient/{{patient_id}}/history"
          }
        },
        {
          "name": "Archive Patient (Soft Delete) - Optional",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/patient/{{patient_id}}"
          }
        }
      ]
    },
    {
      "name": "03 - Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = new Date(Date.now() + 60 * 60 * 1000);",
                  "pm.environment.set('appointment_date', d.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) pm.environment.set('appointment_id', json.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{staff_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": \"{{patient_id}}\",\n  \"appointmentDate\": \"{{appointment_date}}\",\n  \"type\": \"WALKING\",\n  \"reason\": \"General consultation\"\n}"
            },
            "url": "{{base_url}}/appointment"
          }
        },
        {
          "name": "Get Today Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{staff_token}}"
              }
            ],
            "url": "{{base_url}}/appointment/today"
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{staff_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SCHEDULED\"\n}"
            },
            "url": "{{base_url}}/appointment/{{appointment_id}}"
          }
        }
      ]
    },
    {
