                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/queue/history"
          }
        },
        {
          "name": "Complete Queue Entry (Legacy Endpoint) - Optional",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
