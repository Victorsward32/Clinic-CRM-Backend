                {
                  "key": "patientId",
                  "value": "{{patient_id}}",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{report_file}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Patient Reports - Optional",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "{{base_url}}/report/{{patient_id}}"
          }
        }
      ]
    },
    {
      "name": "11 - Reminders (Optional)",
      "item": [
        {
          "name": "Create Reminder - Optional",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/reminders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": \"{{patient_id}}\",\n  \"phone\": \"{{patient_phone_number}}\",\n  \"channel\": \"{{reminder_channel}}\",\n  \"message\": \"{{reminder_message}}\",\n  \"sendAt\": \"{{reminder_send_at}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = new Date(Date.now() + 2 * 60 * 60 * 1000);",
                  "pm.environment.set(\"reminder_send_at\", d.toISOString());"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}